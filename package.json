{
  "name": "jarvis-board",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-env.mjs",
    "prebuild": "node scripts/check-env.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
